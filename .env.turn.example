# ============================================================
# Beteseb — TURN Server Configuration (Production WebRTC)
# ============================================================
# Copy relevant vars to your .env.local or Vercel environment.
# Leave blank to use STUN-only (works for ~85% of NAT types).
# For strict firewalls, corporate networks, or symmetrical NAT
# you MUST configure a TURN server.

# -- Option 1: Self-hosted coturn --
NEXT_PUBLIC_TURN_URL=turn:your-turn-server.com:3478
NEXT_PUBLIC_TURN_USERNAME=beteseb_turn_user
NEXT_PUBLIC_TURN_CREDENTIAL=your_turn_credential_here

# -- Option 2: Twilio NTS (Recommended for production) --
# NEXT_PUBLIC_TURN_URL=turn:global.turn.twilio.com:3478?transport=udp
# NEXT_PUBLIC_TURN_USERNAME=<TWILIO_ACCOUNT_SID>
# NEXT_PUBLIC_TURN_CREDENTIAL=<TWILIO_AUTH_TOKEN>

# -- Option 3: Metered.ca (Free tier available) --
# NEXT_PUBLIC_TURN_URL=turn:relay1.expressturn.com:3478
# NEXT_PUBLIC_TURN_USERNAME=<METERED_USERNAME>
# NEXT_PUBLIC_TURN_CREDENTIAL=<METERED_CREDENTIAL>
